# SerpAPI key for Google Shopping searches
# Get yours at: https://serpapi.com
SERPAPI_KEY=your_serpapi_key_here

# Gmail SMTP for email alerts
# 1. Enable 2-Step Verification on your Google Account
# 2. Create an App Password at: https://myaccount.google.com/apppasswords
# 3. Use your Gmail address and the generated 16-char app password
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Database path (SQLite)
DATABASE_PATH=./data/pricespy.db

# Auth — Login credentials (single user)
# Generate password hash: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
SECRET_KEY=change-me-generate-a-random-string
CRON_SECRET=change-me-generate-a-random-string
AUTH_EMAIL=admin@example.com
AUTH_PASSWORD_HASH=$2b$12$...
